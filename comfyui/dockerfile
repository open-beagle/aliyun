# 采用 CUDA 13.0：PyTorch cu130 源同时提供 torch、torchvision、torchaudio。
ARG CUDA_VERSION="13.0.2"
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu24.04

LABEL maintainer="beagle-news-flow"
LABEL description="ComfyUI Image - CUDA 13.0"

# 环保和网络加速配置 (移除了占位符代理，因为 GitHub Actions 本身在海外，网络通畅。如需本地构建可自行加上)
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    HF_ENDPOINT="https://hf-mirror.com" \
    PIP_BREAK_SYSTEM_PACKAGES=1

# 在 Ubuntu 24.04 上安装高版本 Python 和最新工具链，以及必须的图像库依赖
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git wget curl build-essential ffmpeg libgl1 libglib2.0-0 \
    python3.12 python3.12-venv python3.12-dev && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    update-alternatives --install /usr/bin/pip pip /usr/local/bin/pip3.12 1 && \
    python -m pip --version && \
    rm -rf /var/lib/apt/lists/*

# 安装 PyTorch 稳定版。不要使用 --extra-index-url，避免 torchaudio 从 PyPI 混入非 cu130 wheel。
RUN python -m pip install --no-cache-dir \
    torch==2.12.0+cu130 \
    torchvision==0.27.0+cu130 \
    torchaudio==2.11.0+cu130 \
    --index-url https://download.pytorch.org/whl/cu130

# xformers 当前没有匹配 PyTorch cu130/Python 3.12 的稳定 wheel，错误 wheel 会导致自定义节点导入失败。
# 先只安装 triton，让 ComfyUI 回退到 PyTorch attention；后续有匹配 wheel 再开启 xformers。
RUN python -m pip install --no-cache-dir triton

# 部署 ComfyUI 本体
WORKDIR /app
ARG COMFYUI_VERSION="v0.21.1"
RUN git clone --branch ${COMFYUI_VERSION} --depth 1 https://github.com/comfyanonymous/ComfyUI.git .
RUN python - <<'PY'
from pathlib import Path

def replace_once(path: str, old: str, new: str) -> None:
    file_path = Path(path)
    text = file_path.read_text()
    if old not in text:
        raise RuntimeError(f"Expected text not found in {path}: {old!r}")
    file_path.write_text(text.replace(old, new, 1))

cli_args = Path("comfy/cli_args.py")
replace_once("comfy/cli_args.py", 'default="127.0.0.1"', 'default="0.0.0.0"')
replace_once(
    "folder_paths.py",
    "base_path = os.path.dirname(os.path.realpath(__file__))",
    'base_path = "/data"',
)

text = cli_args.read_text()
start = text.find("database_default_path = os.path.abspath(\n")
if start == -1:
    raise RuntimeError("Expected database_default_path block not found in comfy/cli_args.py")
end = text.find("\n)", start)
if end == -1:
    raise RuntimeError("Expected database_default_path block terminator not found in comfy/cli_args.py")
end += len("\n)")
text = text[:start] + 'database_default_path = "/data/user/comfyui.db"' + text[end:]
cli_args.write_text(text)
PY
RUN python -m pip install --no-cache-dir -r requirements.txt

# 挂载 Manager
WORKDIR /app/custom_nodes
RUN git clone https://github.com/ltdrdata/ComfyUI-Manager.git && \
    python -m pip install --no-cache-dir -r /app/custom_nodes/ComfyUI-Manager/requirements.txt && \
    python -c "import git, uv; print('ComfyUI-Manager package checks passed')"

WORKDIR /app
# 准备 K8s 启动脚本
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 8188

# 使用启动脚本（支持自动挂载 /data 的 K8s 模式）
ENTRYPOINT ["/app/entrypoint.sh"]
