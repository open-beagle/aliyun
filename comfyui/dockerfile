# 采用 PyTorch 官方 devel 镜像作为底座，保留 CUDA 编译链用于 SageAttention 等扩展。
ARG BASE="pytorch/pytorch:2.11.0-cuda13.0-cudnn9-devel"
FROM ${BASE}

LABEL maintainer="beagle-news-flow"
LABEL description="ComfyUI Image - PyTorch 2.11.0 CUDA 13.0"

# 环保和网络加速配置 (移除了占位符代理，因为 GitHub Actions 本身在海外，网络通畅)
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    HF_ENDPOINT="https://hf-mirror.com" \
    PIP_BREAK_SYSTEM_PACKAGES=1

# 安装系统必须的图像库依赖和基础工具
# 因为官方镜像基于 Ubuntu，可以直接 apt-get
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git wget curl build-essential ffmpeg libgl1 libglib2.0-0 python3-venv && \
    rm -rf /var/lib/apt/lists/*

# 锁定 PyTorch 生态包，避免 ComfyUI requirements.txt 中裸 torch 包触发解析漂移。
COPY configure_comfyui.py pytorch-stack.env pytorch_stack.py /opt/comfyui-build/
RUN python /opt/comfyui-build/pytorch_stack.py install-stack

ARG SAGEATTENTION_REF="v2.2.0"
ARG SAGEATTENTION_CUDA_ARCH_LIST="8.9"
ARG SAGEATTENTION_MAX_JOBS="4"
RUN python -m pip install --no-cache-dir ninja packaging && \
    TORCH_CUDA_ARCH_LIST="${SAGEATTENTION_CUDA_ARCH_LIST}" \
    MAX_JOBS="${SAGEATTENTION_MAX_JOBS}" \
    python -m pip install --no-cache-dir --no-build-isolation \
        "git+https://github.com/thu-ml/SageAttention.git@${SAGEATTENTION_REF}"

# 部署 ComfyUI 本体
WORKDIR /app
ARG COMFYUI_VERSION="master"
RUN git clone --branch ${COMFYUI_VERSION} --depth 1 https://github.com/comfyanonymous/ComfyUI.git .

# 修改 ComfyUI 的默认配置 (0.0.0.0 访问及挂载目录等)
RUN python /opt/comfyui-build/configure_comfyui.py /app

# 安装 ComfyUI 官方依赖
RUN python /opt/comfyui-build/pytorch_stack.py requirements requirements.txt

# 挂载 Manager
WORKDIR /app/custom_nodes
RUN git clone https://github.com/ltdrdata/ComfyUI-Manager.git && \
    python /opt/comfyui-build/pytorch_stack.py requirements /app/custom_nodes/ComfyUI-Manager/requirements.txt && \
    python -c "import git, uv; print('ComfyUI-Manager package checks passed')"

WORKDIR /app
RUN python /opt/comfyui-build/pytorch_stack.py verify

# 准备 K8s 启动脚本
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 8188

# 使用启动脚本（支持自动挂载 /data 的 K8s 模式）
ENTRYPOINT ["/app/entrypoint.sh"]
