# 直接登顶：采用最新的 CUDA 13.2 + cuDNN + Ubuntu 24.04 编译环境
ARG CUDA_VERSION="13.2.1"
FROM nvidia/cuda:${CUDA_VERSION}-cudnn-devel-ubuntu24.04

LABEL maintainer="beagle-news-flow"
LABEL description="机皇满血版 ComfyUI Image - CUDA 13.2"

# 环保和网络加速配置 (移除了占位符代理，因为 GitHub Actions 本身在海外，网络通畅。如需本地构建可自行加上)
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    HF_ENDPOINT="https://hf-mirror.com" \
    PIP_BREAK_SYSTEM_PACKAGES=1

# 在 Ubuntu 24.04 上安装高版本 Python 和最新工具链，以及必须的图像库依赖
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    git wget curl build-essential ffmpeg libgl1 libglib2.0-0 \
    python3.12 python3.12-venv python3.12-dev && \
    curl -sS https://bootstrap.pypa.io/get-pip.py | python3.12 && \
    update-alternatives --install /usr/bin/python python /usr/bin/python3.12 1 && \
    rm -rf /var/lib/apt/lists/*

# 安装 PyTorch 稳定版 (指定 CUDA 13.2 专属构建)
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu132

# 安装 xformers 和 triton（在 CUDA 13 环境下极大可能需要现场编译拉满性能）
RUN pip install --no-cache-dir xformers triton

# 部署 ComfyUI 本体
WORKDIR /app
ARG COMFYUI_VERSION="v0.21.1"
RUN git clone --branch ${COMFYUI_VERSION} --depth 1 https://github.com/comfyanonymous/ComfyUI.git .
RUN pip install --no-cache-dir -r requirements.txt

# 挂载 Manager
WORKDIR /app/custom_nodes
RUN git clone https://github.com/ltdrdata/ComfyUI-Manager.git

WORKDIR /app
# 准备 K8s 启动脚本
COPY entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

EXPOSE 8188

# 使用启动脚本（支持自动挂载 /data 的 K8s 模式）
ENTRYPOINT ["/app/entrypoint.sh"]
